引用 模块：标准库-输入输出-输出 为 输出

// ========== 边界条件与特殊场景测试 ==========

@声明 入口
定义 方法 测试边界（）返回 无：
    执行 输出："========== 边界条件测试 =========="

    // 1. 整数零值
    设 zero = 0
    执行 输出：f"测试1: zero={zero}"

    // 2. 负数
    设 neg = -100
    执行 输出：f"测试2: negative={neg}"

    // 3. 大数值
    设 big = 999999
    执行 输出：f"测试3: big={big}"

    // 4. 小数零值
    设 pi = 3.14
    设 dzero = 0.0
    执行 输出：f"测试4: dzero={dzero}"

    // 5. 表达式结果为零
    设 expr = 5 - 5
    执行 输出：f"测试5: 5-5={expr}"

    // 6. 乘零
    设 mzero = 100 * 0
    执行 输出：f"测试6: 100*0={mzero}"

    // 7. 判断空条件（永远为真）
    判断 1：
        执行 输出："测试7: 永真条件通过"
    。。

    // 8. 判断空条件（永远为假）
    判断 0：
        执行 输出："测试8: 不应执行"
    否则：
        执行 输出："测试8: 永假条件走否则"
    。。

    // 9. 单次循环
    设 single = 0
    循环计数 s < 1：
        single = single + 1
    。。
    执行 输出：f"测试9: 单次循环={single}"

    // 10. 空循环（上限为0）
    设 ec = 0
    循环计数 e < 0：
        ec = ec + 1
    。。
    执行 输出：f"测试10: 空循环ec={ec}"

    // 11. 取余运算
    设 mod0 = 10 % 3
    设 mod1 = 10 % 2
    设 mod2 = 5 % 5
    执行 输出：f"测试11: 10%3={mod0}, 10%2={mod1}, 5%5={mod2}"

    // 12. 单分支判断
    判断 1 == 1：
        执行 输出："测试12: 单分支判断通过"
    。。

    // 13. 多层嵌套判断
    设 outer = 1
    设 inner = 2
    判断 outer == 1：
        判断 inner == 2：
            判断 outer + inner == 3：
                执行 输出："测试13: 三层嵌套判断通过"
            。。
        。。
    。。

    // 14. 选择语句单分支
    设 choice = 7
    当前 choice：
        取 7：
            执行 输出："测试14: 选择单分支通过"
        此外：
            执行 输出："测试14: 不应执行"
    。。

    // 15. 逻辑运算组合
    设 t1 = 1 == 1 且 2 > 1 且 3 >= 3
    判断 t1：
        执行 输出："测试15: 多条件且运算通过"
    。。

    设 t2 = 1 == 2 或 2 == 2 或 3 == 1
    判断 t2：
        执行 输出："测试16: 多条件或运算通过"
    。。

    // 16. 变量自引用修改
    设 v = 1
    v = v + 1
    v = v * 2
    v = v - 1
    执行 输出：f"测试17: v自引用={v}"

    // 17. 循环中变量修改传递
    设 acc = 0
    设 step = 1
    循环计数 i < 5：
        acc = acc + step
        step = step + 1
    。。
    执行 输出：f"测试18: 累计和(step递增)={acc}"

    // 18. 数组边界测试
    设 arr = 【10，20，30，40，50】
    设 first = arr[0]
    设 last = arr[4]
    执行 输出：f"测试19: first={first}, last={last}"

    // 19. 循环条件（while）边界
    设 wc = 0
    判断 wc == 0：
        循环条件 wc < 3：
            wc = wc + 1
        。。
    。。
    执行 输出：f"测试20: while循环wc={wc}"

    // 20. 取反后赋值自身
    设 flag = 1
    设 negFlag = !flag
    判断 negFlag：
        执行 输出："测试21: 不应执行（取反后为0）"
    否则：
        执行 输出："测试21: 取反后为假通过"
    。。

    执行 输出："========== 边界条件测试通过 =========="
。。
