引用 模块：标准库-输入输出-输出 为 输出

// ========== 控制流测试 ==========

@声明 入口
定义 方法 测试控制流（）返回 无：
    // ---- 判断/若/否则 (if/else-if/else) ----
    设 score = 85

    判断 score >= 90：
        执行 输出："测试1: 优秀"
    若 score >= 80：
        执行 输出："测试1: 良好"
    若 score >= 60：
        执行 输出："测试1: 及格"
    否则：
        执行 输出："测试1: 不及格"
    。。

    // 嵌套判断
    设 x = 10
    设 y = 20
    判断 x > 0：
        判断 y > 0：
            执行 输出："测试2: 嵌套判断通过"
        。。
    。。

    // 单分支判断（无否则）
    判断 1 == 1：
        执行 输出："测试3: 单分支判断通过"
    。。

    // 判断-否则（无若）
    判断 1 == 2：
        执行 输出："测试3b: 不应执行"
    否则：
        执行 输出："测试3b: 否则分支通过"
    。。

    // 算术表达式作条件
    判断 42：
        执行 输出："测试4: 整数作条件通过"
    。。

    // ---- 当前/取/此外 (select/switch) ----
    设 option = 2
    当前 option：
        取 1：
            执行 输出："测试5: 不应选择1"
        取 2：
            执行 输出："测试5: 选择2通过"
        取 3：
            执行 输出："测试5: 不应选择3"
        此外：
            执行 输出："测试5: 不应执行此外"
    。。

    // 选择-此外分支
    设 option2 = 99
    当前 option2：
        取 1：
            执行 输出："测试6: 不应执行"
        取 2：
            执行 输出："测试6: 不应执行"
        此外：
            执行 输出："测试6: 此外分支通过"
    。。

    // ---- 循环计数 (counted loop / for-i) ----
    设 sum = 0
    循环计数 i < 5：
        sum = sum + i
    。。
    执行 输出：f"测试7: 循环计数 sum(0..4)={sum}"

    // ---- 循环迭代 (range loop) ----
    设 sum2 = 0
    循环迭代 j < 1..4：
        sum2 = sum2 + j
    。。
    执行 输出：f"测试8: 循环迭代 sum(1..3)={sum2}"

    // ---- 循环条件 (while loop) ----
    设 counter = 3
    设 fact = 1
    循环条件 counter > 0：
        fact = fact * counter
        counter = counter - 1
    。。
    执行 输出：f"测试9: 循环条件 factorial={fact}"

    // 循环计数嵌套
    设 outer = 0
    循环计数 a < 3：
        循环计数 b < 2：
            outer = outer + 1
        。。
    。。
    执行 输出：f"测试10: 嵌套循环计数={outer}"

    // 循环中使用判断
    设 even_sum = 0
    循环计数 k < 10：
        判断 k % 2 == 0：
            even_sum = even_sum + k
        。。
    。。
    执行 输出：f"测试11: 循环中判断 even_sum={even_sum}"

    // 循环条件中使用逻辑表达式
    设 val = 10
    循环条件 val > 0 且 val != 5：
        val = val - 1
    。。
    执行 输出：f"测试12: 循环条件+逻辑 val={val}"

    执行 输出："=== 控制流测试通过 ==="
。。
