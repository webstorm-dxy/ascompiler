引用 模块：标准库-输入输出-输出 为 输出

// ========== 综合集成测试 ==========

// 判断分数等级
定义 方法 获取等级（分数：整数）返回 整数：
    判断 分数 >= 90：
        返回 4
    。。
    判断 分数 >= 80：
        返回 3
    。。
    判断 分数 >= 60：
        返回 2
    。。
    返回 1
。。

// 阶乘
定义 方法 阶乘（n：整数）返回 整数：
    判断 n <= 1：
        返回 1
    。。
    返回 n * 阶乘（n - 1）
。。

// 斐波那契
定义 方法 斐波那契（n：整数）返回 整数：
    判断 n <= 1：
        返回 n
    。。
    返回 斐波那契（n - 1） + 斐波那契（n - 2）
。。

@声明 入口
定义 方法 综合测试（）返回 无：
    执行 输出："========== 综合集成测试 =========="

    // 第1部分：变量与运算
    设 a = 100
    设 b = 25
    设 c = a + b * 3 - 10 / 2
    执行 输出：f"第1部分: 表达式结果={c}"

    // 第2部分：数组与循环求总分
    设 成绩 = 【85，92，78，95，60】
    设 总人数 = 5
    设 总分 = 0
    循环计数 i < 总人数：
        总分 = 总分 + 成绩[i]
    。。
    设 平均 = 总分 / 总人数
    执行 输出：f"第2部分: 总分={总分}, 平均分={平均}"

    // 第3部分：判断与统计及格人数
    设 及格人数 = 0
    循环计数 j < 总人数：
        判断 成绩[j] >= 60：
            及格人数 = 及格人数 + 1
        。。
    。。
    执行 输出：f"第3部分: 及格人数={及格人数}"

    // 第4部分：选择语句
    设 level = 获取等级（平均）
    当前 level：
        取 4：
            执行 输出："第4部分: 等级=优秀"
        取 3：
            执行 输出："第4部分: 等级=良好"
        取 2：
            执行 输出："第4部分: 等级=及格"
        取 1：
            执行 输出："第4部分: 等级=不及格"
        此外：
            执行 输出："第4部分: 未知等级"
    。。

    // 第5部分：递归
    设 fact5 = 阶乘（5）
    设 fib7 = 斐波那契（7）
    执行 输出：f"第5部分: 5!={fact5}, fib(7)={fib7}"

    // 第6部分：循环条件
    设 counter = 5
    设 loopSum = 0
    循环条件 counter > 0：
        loopSum = loopSum + counter
        counter = counter - 1
    。。
    执行 输出：f"第6部分: 1+2+3+4+5={loopSum}"

    // 第7部分：循环计数+判断统计偶数
    设 evenCount = 0
    循环计数 k < 10：
        判断 k % 2 == 0：
            evenCount = evenCount + 1
        。。
    。。
    执行 输出：f"第7部分: 0-9中偶数个数={evenCount}"

    // 第8部分：嵌套循环
    设 outC = 0
    循环计数 x < 3：
        循环计数 y < 4：
            outC = outC + 1
        。。
    。。
    执行 输出：f"第8部分: 3x4嵌套循环={outC}"

    // 第9部分：循环迭代
    设 iterSum = 0
    循环迭代 z < 1..6：
        iterSum = iterSum + z
    。。
    执行 输出：f"第9部分: 迭代求和1..5={iterSum}"

    // 第10部分：复杂表达式与逻辑运算
    设 val = 10
    设 r = (val + 5) * 2 - val / 2 + val % 3
    判断 r > 20 且 r < 30：
        执行 输出：f"第10部分: {r}在20-30之间"
    。。

    // 第11部分：布尔逻辑
    设 isPass = 平均 >= 60
    设 isGood = 平均 >= 80
    判断 isPass 且 isGood：
        执行 输出："第11部分: 既及格又良好"
    若 isPass 或 isGood：
        执行 输出："第11部分: 及格或良好"
    。。

    // 第12部分：设+为赋值
    设 分数A = 95
    执行 输出：f"第12部分: 分数A={分数A}"

    执行 输出："========== 综合测试全部通过 =========="
。。
