引用 模块：标准库-输入输出-输出 为 输出

// ========== 数组测试 ==========

@声明 入口
定义 方法 测试数组（）返回 无：
    // 1. 数组字面量（整数元素）
    设 arr = 【1，2，3，4，5】
    设 v1 = arr[0]
    执行 输出：f"测试1: arr[0]={v1}"

    // 2. 数组字面量（使用半角方括号）
    设 arr2 = [10, 20, 30]
    设 v2 = arr2[1]
    执行 输出：f"测试2: arr2[1]={v2}"

    // 3. 数组预定义（带长度）
    定义 变量：数组 arr3[5]
    设 arr3[0] = 100
    设 arr3[1] = 200
    设 v3 = arr3[0]
    执行 输出：f"测试3: arr3[0]={v3}"

    // 4. 数组元素修改（全角下标）
    设 arr【2】 = 99
    设 v4 = arr[2]
    执行 输出：f"测试4: arr[2]={v4}"

    // 5. 声明带初始化的数组变量
    定义 可变 变量：数组 arr4 = 【5，6，7】
    设 v5 = arr4[1]
    执行 输出：f"测试5: arr4[1]={v5}"

    // 6. 循环遍历数组求和
    设 sum = 0
    循环计数 i < 3：
        sum = sum + arr2[i]
    。。
    执行 输出：f"测试6: 数组求和={sum}"

    // 7. 数组元素参与表达式
    设 x = arr[0] + arr[1] + arr[2]
    执行 输出：f"测试7: arr[0]+arr[1]+arr[2]={x}"

    // 8. 可变数组元素修改
    设 arr4[0] = 100
    设 v8 = arr4[0]
    执行 输出：f"测试8: arr4[0]={v8}"

    // 9. 通过变量作下标
    设 idx = 2
    设 arr_val = arr[idx]
    执行 输出：f"测试9: arr[2]={arr_val}"

    // 10. 使用设为数组元素赋值
    设 arr3[2] 为 300
    设 v10 = arr3[2]
    执行 输出：f"测试10: arr3[2]={v10}"

    执行 输出："=== 数组测试通过 ==="
。。
