引用 模块：标准库-输入输出-输出 为 输出

// ========== 多类型数组测试 ==========

@声明 入口
定义 方法 测试多类型数组（）返回 无：
    // 1. 整数数组（保持已有功能）
    设 intArr = 【1，2，3】
    设 v1 = intArr[0]
    执行 输出：f"测试1: 整数数组 intArr[0]={v1}"

    // 2. 小数数组
    设 dArr = 【1.5，2.7，3.14】
    设 v2 = dArr[1]
    执行 输出：f"测试2: 小数数组 dArr[1]={v2}"

    // 3. 小数数组索引赋值
    定义 可变 变量：数组 dArr2 = 【1.1，2.2，3.3】
    设 dArr2[1] = 99.9
    设 v3 = dArr2[1]
    执行 输出：f"测试3: dArr2[1]={v3}"

    // 4. 布尔数组
    设 bArr = 【真，假，真】
    设 v4 = bArr[0]
    判断 v4 == 真：
        执行 输出："测试4: 布尔数组 bArr[0]=真 通过"
    。。

    // 5. 字符串数组
    设 sArr = ["hello", "world", "test"]
    执行 输出：f"测试5: 字符串数组 sArr[0]=hello"

    // 6. 使用设声明带类型推断的小数数组
    设 fArr = 【0.0，0.5，1.0】
    设 v6 = fArr[2]
    执行 输出：f"测试6: 小数数组 fArr[2]={v6}"

    // 7. 循环遍历小数数组
    定义 可变 变量：小数 dSum = 0.0
    循环计数 i < 3：
        dSum = dSum + dArr2[i]
    。。
    执行 输出：f"测试7: 小数数组求和={dSum}"

    // 8. 循环遍历布尔数组
    定义 可变 变量：整数 trueCount = 0
    循环计数 i < 3：
        判断 bArr[i]：
            trueCount = trueCount + 1
        否则：
            执行 输出："false"
        。。
    。。
    执行 输出：f"测试8: 布尔数组中真值个数={trueCount}"

    // 9. 通过变量作下标访问小数数组
    设 idx = 1
    设 val = dArr[idx]
    执行 输出：f"测试9: dArr[1]={val}"

    // 10. 使用设单独赋值小数字符串数组元素
    设 sArr[2] = "updated"
    执行 输出：f"测试10: sArr[2]=updated"

    执行 输出："=== 多类型数组测试通过 ==="
。。
